{
  "name": "archive-backend",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../.env.dev -- tsx watch src",
    "build": "rimraf dist && tsc && tsc-alias",
    "start": "dotenv -e ../.env.dev -- node dist/index.js",
    "lint": "eslint src/",
    "prettier": "prettier --write --check 'src/**/*.*'",
    "migrate": "./scripts/set-db-url.sh node-pg-migrate --tsconfig tsconfig.json",
    "migrate-files": "dotenv -e ../.env.dev -- tsx scripts/migrate-files.ts",
    "migrate-files:validate": "dotenv -e ../.env.dev -- tsx scripts/migrate-files.ts --validate-only",
    "reconcile-files": "dotenv -e ../.env.dev -- tsx scripts/reconcile-files.ts",
    "drizzle": "dotenv -e ../.env.dev -- tsx $(which drizzle-kit)",
    "drizzle:patch": "node scripts/patch-drizzle-schema.js",
    "prebuild": "npm run drizzle:patch",
    "generate": "graphql-codegen --config codegen.ts"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@graphql-tools/schema": "^10.0.34",
    "@paralleldrive/cuid2": "^3.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@types/qrcode": "^1.5.6",
    "archive-shared": "*",
    "argon2": "^0.44.0",
    "chalk": "^5.6.2",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dataloader": "^2.2.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "express": "^5.2.1",
    "file-type": "^22.0.1",
    "fs-capacitor": "^8.0.0",
    "graphql": "^16.14.2",
    "graphql-relay": "^0.10.2",
    "graphql-subscriptions": "^3.0.0",
    "graphql-upload": "^17.0.0",
    "hashids": "^2.3.0",
    "morgan": "^1.11.0",
    "node-vibrant": "^4.0.4",
    "otplib": "^13.4.1",
    "pg": "^8.22.0",
    "pg-escape": "^0.2.0",
    "pg-ipc": "^1.0.5",
    "pg-listen": "^1.7.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.2",
    "string-strip-html": "^13.5.3",
    "telegraf": "^4.16.3",
    "tmp": "^0.2.7",
    "ua-parser-js": "^2.0.10",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-resolvers": "^6.0.2",
    "@types/body-parser": "^1.19.6",
    "@types/cookie": "^1.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "5.0.6",
    "@types/graphql-upload": "^17.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "25.9.3",
    "@types/pg": "^8.20.0",
    "@types/sharp": "^0.32.0",
    "@types/tmp": "^0.2.6",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^63.0.10",
    "globals": "^17.7.0",
    "graphql-ws": "^6.0.8",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.9.1",
    "prettier-plugin-jsdoc": "^1.8.1",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
